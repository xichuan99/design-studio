# Database
DATABASE_URL=postgresql+asyncpg://dev:devpass@localhost:5433/designstudio

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=your_super_secret_key_here_for_dev
NEXTAUTH_URL=http://localhost:3000

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Backend CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# LLM
GEMINI_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Image Generation (Fal.ai)
FAL_KEY=

# Cloud Storage (Backblaze B2 — S3-compatible)
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_BUCKET=designstudio-prod
S3_ACCESS_KEY=your_b2_application_key_id
S3_SECRET_KEY=your_b2_application_key
S3_PUBLIC_URL=https://f004.backblazeb2.com/file/designstudio-prod


# Analytics — PostHog (optional, leave blank to skip)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
